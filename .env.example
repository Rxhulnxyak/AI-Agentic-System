# --- API KEYS ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=Rachel
PVPORCUPINE_API_KEY=your_pvporcupine_api_key_here

# --- SYSTEM CONFIG ---
# Path to Tesseract executable (if not in PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# ADB Path (if not in PATH)
# ADB_PATH=adb

# --- HOME ASSISTANT ---
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=your_long_lived_access_token_here

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_FILE=logs/kolimarii.log

# --- MEMORY ---
CHROMA_DB_PATH=./memory_db
